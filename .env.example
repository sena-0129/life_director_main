# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# 阿里百炼（DashScope OpenAI 兼容模式）
DASHSCOPE_API_KEY="MY_DASHSCOPE_API_KEY"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
DASHSCOPE_EMBEDDING_MODEL="text-embedding-v4"
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
DASHSCOPE_CHAT_MODEL="qwen3.5-plus"
RAG_PORT=4000

# 豆包（火山方舟）- 视频生成（故事脚本 + 文生视频）
ARK_API_KEY="MY_ARK_API_KEY"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_SCRIPT_MODEL="doubao-seed-2-0-lite-260215"
ARK_VIDEO_MODEL="doubao-seedance-1-5-pro-251215"

# 后端（Express）
API_KEY="MY_IMAGE_VIDEO_API_KEY"
PORT=3001
DATABASE_PATH="./data/life-director.sqlite"
BACKEND_TOKEN=""
UPLOADS_DIR="./data/uploads"
MAX_UPLOAD_MB=20

# Supabase（如果设置了下面两个值，后端会优先把数据写入 Supabase）
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# 前端（Vite）
VITE_USE_BACKEND=true
# VITE_API_BASE_URL="http://localhost:3001"
VITE_BACKEND_TOKEN=""
BACKEND_URL="http://localhost:3001"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
